# ── Database backend ─────────────────────────────────────────────────────────
# DB_ADAPTER=sqlite   (default) — single-file local DB, no extra setup needed.
#   API_SQLITE_PATH=data/mf-lab.sqlite   optional: override file location
#
# DB_ADAPTER=postgres — multi-user hosted deployment.
#   Requires: npm install pg
#   DATABASE_URL=postgres://user:pass@host:5432/dbname
#   Tables are created automatically on first start (CREATE TABLE IF NOT EXISTS).
DB_ADAPTER=sqlite
# DATABASE_URL=

# ── AI provider keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional: Images API model id (default gpt-image-1). Use chatgpt-image-latest only if your org is verified in OpenAI settings.
# OPENAI_IMAGE_MODEL=gpt-image-1
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Optional: extra host suffixes for Access / #data live JSON GET (in addition to each row’s own endpoint hostname).
# Public HTTPS only. Leave empty — each row is still fetched against the hostname in that row’s saved URL.
# Example: ACCESS_DATA_DUMP_ALLOW_HOST_SUFFIXES=cdn.example.org,edgesuite.net
ACCESS_DATA_DUMP_ALLOW_HOST_SUFFIXES=

# Optional: max live JSON GETs per #data / Access data request (1–120). Default 48 if unset.
# ACCESS_DATA_DUMP_MAX_LIVE_FETCHES=64

# Optional: max JSON body size for POST/PUT to the local API (bytes). Default 10485760 (10 MiB). Allowed 1048576–104857600.
# API_MAX_BODY_BYTES=20971520
