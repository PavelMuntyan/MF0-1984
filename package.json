{
  "name": "mf-lab",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "node server/api.mjs",
    "dev": "concurrently -k -n api,vite -c cyan,magenta \"npm run api\" \"vite\"",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop mf-lab-api mf-lab-vite",
    "pm2:restart": "pm2 restart mf-lab-api mf-lab-vite",
    "pm2:delete": "pm2 delete mf-lab-api mf-lab-vite",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "node scripts/init-db.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "pm2": "^6.0.8",
    "sql.js": "^1.13.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "3d-force-graph": "^1.80.0",
    "dompurify": "^3.3.3",
    "marked": "^18.0.0",
    "three": "^0.183.2",
    "three-spritetext": "^1.10.0"
  }
}
